# Docker Compose
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=schedule
MYSQL_USER=schedule
MYSQL_PASSWORD=schedulepassword

# Backend (copie para backend/.env)
DATABASE_URL=mysql://schedule:schedulepassword@tcp(localhost:3306)/schedule
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/google/callback

# Criptografia (tokens Google) — gere com: openssl rand -hex 32
ENCRYPTION_KEY=

# App
APP_ENV=development
APP_PORT=8080
BASE_URL=http://localhost:8080

# Frontend (copie para frontend/.env)
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080
